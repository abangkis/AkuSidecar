{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "summary": { "type": "string" },
    "items": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "whatChanged": { "type": "string" },
          "whyItMatters": { "type": "string" },
          "evidenceKey": {
            "type": "string",
            "pattern": "^candidate_[0-9]{3}$"
          },
          "eventKey": {
            "type": "string",
            "minLength": 3,
            "maxLength": 200,
            "pattern": "^[a-z0-9][a-z0-9._:-]*$"
          },
          "knowledgeDelta": {
            "type": "string",
            "enum": ["new_event", "material_update", "context", "contradiction"]
          },
          "author": { "type": "string" },
          "publishedAt": { "type": ["string", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidenceState": {
            "type": "string",
            "enum": ["primary", "secondary", "unverified"]
          }
        },
        "required": [
          "id",
          "whatChanged",
          "whyItMatters",
          "evidenceKey",
          "eventKey",
          "knowledgeDelta",
          "author",
          "publishedAt",
          "confidence",
          "evidenceState"
        ],
        "additionalProperties": false
      }
    },
    "candidateAssessments": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "properties": {
          "evidenceKey": { "type": "string", "pattern": "^candidate_[0-9]{3}$" },
          "topicTags": {
            "type": "array",
            "maxItems": 5,
            "items": { "type": "string", "minLength": 1, "maxLength": 80 }
          },
          "topicFacets": {
            "type": "array",
            "maxItems": 3,
            "items": {
              "type": "string",
              "enum": ["ai_models", "software_engineering", "developer_tools", "security", "data_infrastructure", "geospatial", "science", "space", "business", "finance", "policy", "education", "health", "climate_energy", "culture_entertainment", "sports", "career_hiring", "other"]
            }
          },
          "contentType": {
            "type": "string",
            "enum": ["release", "tutorial", "opinion", "benchmark", "announcement", "hiring", "promotion", "news", "research", "other"]
          },
          "novelty": { "type": "number", "minimum": 0, "maximum": 1 },
          "urgency": { "type": "number", "minimum": 0, "maximum": 1 },
          "actionability": { "type": "number", "minimum": 0, "maximum": 1 },
          "materiality": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidenceStrength": { "type": "number", "minimum": 0, "maximum": 1 },
          "knowledgeRelation": {
            "type": "string",
            "enum": ["new_information", "prior_knowledge_overlap", "material_update", "unknown"]
          },
          "rationale": { "type": "string", "maxLength": 500 }
        },
        "required": ["evidenceKey", "topicTags", "topicFacets", "contentType", "novelty", "urgency", "actionability", "materiality", "evidenceStrength", "knowledgeRelation", "rationale"],
        "additionalProperties": false
      }
    },
    "repeatedClaimsCollapsed": { "type": "integer", "minimum": 0 },
    "deferredByBudget": { "type": "integer", "minimum": 0 },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "summary",
    "items",
    "candidateAssessments",
    "repeatedClaimsCollapsed",
    "deferredByBudget",
    "limitations"
  ],
  "additionalProperties": false
}
