{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "summary": { "type": "string" },
    "items": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "whatChanged": { "type": "string" },
          "whyItMatters": { "type": "string" },
          "source": { "type": "string", "enum": ["x", "linkedin"] },
          "sourceUrl": { "type": "string" },
          "sourceUrlKind": {
            "type": "string",
            "enum": ["native_post", "source_page", "external_reference"]
          },
          "evidenceKey": {
            "type": "string",
            "pattern": "^(x|linkedin):[a-f0-9]{24}$"
          },
          "eventKey": {
            "type": "string",
            "minLength": 3,
            "maxLength": 200,
            "pattern": "^[a-z0-9][a-z0-9._:-]*$"
          },
          "knowledgeDelta": {
            "type": "string",
            "enum": ["new_event", "material_update", "context", "contradiction"]
          },
          "author": { "type": "string" },
          "publishedAt": { "type": ["string", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidenceState": {
            "type": "string",
            "enum": ["primary", "secondary", "unverified"]
          }
        },
        "required": [
          "id",
          "whatChanged",
          "whyItMatters",
          "source",
          "sourceUrl",
          "sourceUrlKind",
          "evidenceKey",
          "eventKey",
          "knowledgeDelta",
          "author",
          "publishedAt",
          "confidence",
          "evidenceState"
        ],
        "additionalProperties": false
      }
    },
    "candidateAssessments": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "properties": {
          "evidenceKey": { "type": "string", "pattern": "^(x|linkedin):[a-f0-9]{24}$" },
          "topicTags": {
            "type": "array",
            "maxItems": 5,
            "items": { "type": "string", "minLength": 1, "maxLength": 80 }
          },
          "contentType": {
            "type": "string",
            "enum": ["release", "tutorial", "opinion", "benchmark", "announcement", "hiring", "promotion", "news", "research", "other"]
          },
          "novelty": { "type": "number", "minimum": 0, "maximum": 1 },
          "urgency": { "type": "number", "minimum": 0, "maximum": 1 },
          "actionability": { "type": "number", "minimum": 0, "maximum": 1 },
          "rationale": { "type": "string", "maxLength": 500 }
        },
        "required": ["evidenceKey", "topicTags", "contentType", "novelty", "urgency", "actionability", "rationale"],
        "additionalProperties": false
      }
    },
    "repeatedClaimsCollapsed": { "type": "integer", "minimum": 0 },
    "deferredByBudget": { "type": "integer", "minimum": 0 },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "summary",
    "items",
    "candidateAssessments",
    "repeatedClaimsCollapsed",
    "deferredByBudget",
    "limitations"
  ],
  "additionalProperties": false
}
