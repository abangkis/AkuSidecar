{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akubrowser.local/contracts/calibration-session.schema.json",
  "title": "AkuBrowser Calibration Session v0",
  "type": "object",
  "required": ["id", "unifiedSessionId", "triggerKind", "status", "sampleCount", "resolvedCount", "samples", "liveInfluence"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "unifiedSessionId": { "type": "string", "minLength": 1 },
    "triggerKind": { "enum": ["first_run", "manual", "source_added", "drift", "random_audit"] },
    "status": { "enum": ["planned", "acquiring", "ready_for_review", "reviewing", "completed", "abandoned", "failed"] },
    "sampleCount": { "type": "integer", "minimum": 1, "maximum": 10 },
    "resolvedCount": { "type": "integer", "minimum": 0, "maximum": 10 },
    "samples": { "type": "array", "maxItems": 10 },
    "liveInfluence": { "const": false }
  }
}
