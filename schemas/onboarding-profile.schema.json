{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://akubrowser.local/contracts/onboarding-profile.schema.json",
  "title": "AkuBrowser Onboarding Profile v0",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "status", "origin", "selectedInterests", "interestRefinement", "preferredContentTypes", "activeSources", "completedAt"],
  "properties": {
    "version": { "const": 0 },
    "status": { "const": "completed" },
    "origin": { "const": "explicit_onboarding" },
    "selectedInterests": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["ai", "technology", "software_development", "science", "gaming", "comedy", "entertainment", "beauty_style", "art_design", "business", "finance", "sports", "food", "travel", "music", "health_fitness", "news_current_events", "culture", "education"] } },
    "interestRefinement": { "type": "string", "maxLength": 800 },
    "preferredContentTypes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["announcement", "tutorial", "opinion", "research", "opportunity", "discovery"] } },
    "activeSources": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["x", "linkedin"] } },
    "completedAt": { "type": "string", "format": "date-time" }
  }
}
