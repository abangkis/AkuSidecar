{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "runId": { "type": "string" },
    "evidenceKey": { "type": "string", "pattern": "^(x|linkedin):[a-f0-9]{24}$" },
    "source": { "type": "string", "enum": ["x", "linkedin"] },
    "decision": { "type": "string", "enum": ["selected", "deferred", "excluded"] },
    "reasonCode": { "type": "string" },
    "itemId": { "type": ["string", "null"] },
    "author": { "type": "string" },
    "avatarUrl": { "type": ["string", "null"], "format": "uri" },
    "relationshipType": { "type": "string", "enum": ["original", "repost", "quote", "reply"] },
    "parentPermalink": { "type": ["string", "null"], "format": "uri" },
    "quotedPost": {
      "type": ["object", "null"],
      "properties": {
        "author": { "type": "string" },
        "avatarUrl": { "type": ["string", "null"], "format": "uri" },
        "text": { "type": "string" },
        "permalink": { "type": ["string", "null"], "format": "uri" },
        "publishedAt": { "type": ["string", "null"] },
        "links": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "properties": {
              "text": { "type": "string" },
              "href": { "type": "string", "format": "uri" }
            },
            "required": ["text", "href"],
            "additionalProperties": false
          }
        },
        "media": { "type": "array", "maxItems": 4, "items": { "type": "object" } }
      },
      "required": ["author", "avatarUrl", "text", "permalink", "publishedAt", "links", "media"],
      "additionalProperties": false
    },
    "engagement": { "type": "object", "additionalProperties": { "type": "string" } },
    "links": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "href": { "type": "string", "format": "uri" }
        },
        "required": ["text", "href"],
        "additionalProperties": false
      }
    },
    "media": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string", "enum": ["image", "video"] },
          "url": { "type": "string", "format": "uri" },
          "posterUrl": { "type": ["string", "null"], "format": "uri" },
          "playbackUrl": { "type": ["string", "null"], "format": "uri" },
          "playbackMode": { "type": ["string", "null"], "enum": ["inline", "native", null] },
          "alt": { "type": "string" },
          "width": { "type": "integer", "minimum": 0 },
          "height": { "type": "integer", "minimum": 0 }
        },
        "required": ["kind", "url", "posterUrl", "playbackUrl", "playbackMode", "alt", "width", "height"],
        "additionalProperties": false
      }
    },
    "mediaRecovery": {
      "type": ["object", "null"],
      "properties": {
        "policyVersion": { "type": "string" },
        "strategyVersion": { "type": "string" },
        "source": { "type": "string", "enum": ["x", "linkedin"] },
        "outcome": { "type": "string", "enum": ["not_applicable", "primary_complete", "recovered", "unavailable"] },
        "attempts": { "type": "integer", "minimum": 0, "maximum": 1 },
        "recoveredCount": { "type": "integer", "minimum": 0, "maximum": 4 },
        "method": { "type": "string", "enum": ["none", "primary_hydration", "alternate_dom"] },
        "limitation": { "type": "string" },
        "trace": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": ["primary_complete", "primary_missing", "media_root_absent", "media_root_detected", "attempt_unavailable", "primary_hydration_complete", "primary_hydration_empty", "alternate_dom_complete", "alternate_dom_empty", "deadline_exhausted"]
          }
        }
      },
      "required": ["policyVersion", "strategyVersion", "source", "outcome", "attempts", "recoveredCount", "method", "limitation", "trace"],
      "additionalProperties": false
    },
    "presentation": { "type": "object" },
    "text": { "type": "string" },
    "sourceUrl": { "type": "string" },
    "publishedAt": { "type": ["string", "null"] },
    "feedPosition": { "type": ["integer", "null"] },
    "policyVersion": { "type": "string" },
    "selectionScore": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "preferenceProfileVersion": { "type": "integer", "minimum": 0 },
    "assessment": {
      "type": ["object", "null"],
      "properties": {
        "topicTags": { "type": "array", "maxItems": 5, "items": { "type": "string" } },
        "topicFacets": { "type": "array", "maxItems": 3, "items": { "type": "string" } },
        "contentType": { "type": "string" },
        "novelty": { "type": "number", "minimum": 0, "maximum": 1 },
        "urgency": { "type": "number", "minimum": 0, "maximum": 1 },
        "actionability": { "type": "number", "minimum": 0, "maximum": 1 },
        "materiality": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidenceStrength": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string" }
      },
      "required": ["topicTags", "topicFacets", "contentType", "novelty", "urgency", "actionability", "materiality", "evidenceStrength", "rationale"],
      "additionalProperties": false
    }
  },
  "required": ["runId", "evidenceKey", "source", "decision", "reasonCode", "itemId", "author", "avatarUrl", "relationshipType", "parentPermalink", "quotedPost", "text", "sourceUrl", "links", "media", "engagement", "presentation", "publishedAt", "feedPosition", "policyVersion", "selectionScore", "preferenceProfileVersion", "assessment"],
  "additionalProperties": false
}
