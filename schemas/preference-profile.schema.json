{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": { "type": "integer", "minimum": 0 },
    "status": { "type": "string", "enum": ["collecting", "active"] },
    "feedbackEventCount": { "type": "integer", "minimum": 0 },
    "moreLikeThisCount": { "type": "integer", "minimum": 0 },
    "shouldNotShowCount": { "type": "integer", "minimum": 0 },
    "selectedMoreLikeThisCount": { "type": "integer", "minimum": 0 },
    "excludedMoreLikeThisCount": { "type": "integer", "minimum": 0 },
    "updatedAt": { "type": ["string", "null"] }
  },
  "required": ["version", "status", "feedbackEventCount", "moreLikeThisCount", "shouldNotShowCount", "selectedMoreLikeThisCount", "excludedMoreLikeThisCount", "updatedAt"],
  "additionalProperties": false
}
