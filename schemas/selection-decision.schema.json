{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "runId": { "type": "string" },
    "evidenceKey": { "type": "string" },
    "decision": { "type": "string", "enum": ["selected", "deferred", "excluded"] },
    "policyVersion": { "type": "string" },
    "preferenceProfileVersion": { "type": "integer", "minimum": 0 },
    "reasonCode": { "type": "string" }
  },
  "required": ["runId", "evidenceKey", "decision", "policyVersion", "preferenceProfileVersion", "reasonCode"],
  "additionalProperties": false
}
