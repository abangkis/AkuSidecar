{
  "name": "@aku-browser/sidecar",
  "version": "0.5.20",
  "private": true,
  "type": "module",
  "description": "AkuSidecar local runtime, state store, AkuBrowser UI, and reasoning adapters",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "node --watch-path=src src/server.mjs --vite",
    "test": "node --test --test-isolation=none",
    "check": "node --check src/server.mjs && node --test --test-isolation=none",
    "check:provider": "node scripts/check-provider-conformance.mjs",
    "db:health": "node scripts/sqlite-ops.mjs health",
    "db:backup": "node scripts/sqlite-ops.mjs backup",
    "db:export": "node scripts/sqlite-ops.mjs export",
    "db:retention-preview": "node scripts/sqlite-ops.mjs retention-preview",
    "db:reset-onboarding": "node scripts/sqlite-ops.mjs reset-onboarding",
    "smoke:http": "node scripts/smoke-http.mjs",
    "smoke:codex": "node scripts/smoke-codex.mjs"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.144.1"
  },
  "devDependencies": {
    "vite": "^8.1.4"
  }
}
